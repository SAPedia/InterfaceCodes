{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["typescript", "unicorn", "oxc", "import"],
    "categories": {
        "correctness": "error"
    },
    "rules": {
        "curly": "error",
        "typescript/no-floating-promises": ["error", { "ignoreIIFE": true }],
        "import/no-duplicates": "error"
    },
    "env": {
        "builtin": true
    },
    "options": {
        "typeAware": true
    },
    "ignorePatterns": ["dist"]
}
